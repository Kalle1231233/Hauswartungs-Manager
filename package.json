{
  "name": "hauswartungs-manager",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.32.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm --filter @haus/shared build && pnpm --parallel --filter @haus/api --filter @haus/web dev",
    "test": "pnpm --filter @haus/shared build && pnpm -r test",
    "db:generate": "pnpm --filter @haus/api prisma generate",
    "db:migrate": "pnpm --filter @haus/api prisma migrate dev",
    "db:push": "pnpm --filter @haus/api prisma db push"
  }
}
